---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import { Image } from "astro:assets";
import tvvbestcrowd from "../assets/img/tvvbestcrowd.jpg";
import tvvcrowd2 from "../assets/img/tvvcrowd2.webp";
import crowdpic from "../assets/img/crowdpic.webp";
import prizebelt from "../assets/img/prizebelt.jpg";
import superlatives from "../assets/img/superlatives.jpg";
import trophies from "../assets/img/trophies.jpg";
import ModalImageProvider from "../components/ModalImageProvider.astro";
import AlbumGallery from "../components/AlbumGallery.astro";
import VideoGallery from "../components/VideoGallery.astro";
import andy from "../assets/img/andy.jpg";
import katie from "../assets/img/katie.jpg";
import alec from "../assets/img/alec.png";
import cloud from "../assets/img/cloud.png";
import tube from "../assets/img/tube.png";
import box from "../assets/img/box.png";
import doorway from "../assets/img/doorway.png";
import spaghetti from "../assets/img/spaghetti.png";
import film from "../assets/img/film.png";
import { videoGroups } from "../data/videos";
---

<!doctype html>
<html lang="en" class="bg-neutral text-neutral-foreground text-center">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body id="home">
    <Header />
    <main class="w-full">
      <ModalImageProvider />
      <h3 class="text-center">Welcome to Tootsies Video Vault!</h3>
      <p class="text-center">
        Tootsie’s Video Vault is an annual short film race organized by seasoned
        comedy film producers, featuring dozens of shorts created by local
        filmmakers!
      </p>

      <Image src={tvvcrowd2} alt="TVV Crowd" class="my-4 w-full rounded-none" />
      <section id="next-show" class="text-center">
        <h3>Submit to the next show!</h3>
        <iframe
          class="my-4 aspect-video max-w-2xl mx-auto"
          src="https://www.youtube.com/embed/0AA9RPDUvy4?si=Bge-7VCNURf2Nd6H"
          title="Tootsie's Video Vault 2025"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          referrerpolicy="strict-origin-when-cross-origin"
          allowfullscreen></iframe>
        <a
          href="https://docs.google.com/forms/d/e/1FAIpQLSdJ-Uee0B4gFOxfuqjtpuX9i3t1S34HoGQwNvCApZmoQH8aMA/viewform"
          target="_blank"
          class="text-secondary font-bold">Submission Form here!</a
        >
        <p>
          Can't make this one?
          <br />Send us an email and get on our mailing list for the next shows!
          <br /><a href="mailto:tootsiesvideovault@gmail.com"
            >TootsiesVideoVault@gmail.com</a
          >
        </p>
      </section>

      <section id="how-it-works" class="space-y-6">
        <h3 class="text-center">How It Works</h3>
        <ul class="mx-4 flex gap-8 text-center how-it-works__list">
          <li class="how-it-works__item">
            <Image src={cloud} alt="Cloud" class="how-it-works__frame" />
            <div class="how-it-works__content">
              Submit a <strong>free</strong> application.
            </div>
          </li>
          <li class="how-it-works__item">
            <Image src={tube} alt="Tube" class="how-it-works__frame" />
            <div class="how-it-works__content">
              Make a brand new 3 minute short.
            </div>
          </li>
          <li class="how-it-works__item">
            <Image src={box} alt="Box" class="how-it-works__frame" />
            <div class="how-it-works__content">
              Attend the premiere and have a blast with prizes, trophies, and a
              great crowd!
            </div>
          </li>
        </ul>
      </section>
      <Image src={crowdpic} alt="TVV Best Crowd" class="my-4 w-full" />
      <section id="
            prizes">
        <h3 class="text-center">Prizes!</h3>
        <div class="flex">
          <div class="flex w-full flex-wrap justify-center">
            <figure class="w-full md:w-1/2">
              <Image
                src={trophies}
                alt="Tootsie's Video Vault trophies on a table"
                class="rounded-lg"
                loading="lazy"
                data-modal-image
                data-modal-full={trophies.src}
              />
              <figcaption><i>Genuine</i> trophies!</figcaption>
            </figure>
            <figure class="w-full md:w-1/2">
              <Image
                src={prizebelt}
                alt="Winners posing with the Tootsie's Video Vault championship belt"
                class="rounded-lg"
                loading="lazy"
                data-modal-image
                data-modal-full={prizebelt.src}
              />
              <figcaption>A championship belt!</figcaption>
            </figure>
            <figure class="w-full md:w-1/2">
              <Image
                src={superlatives}
                alt="Winners holding a best dressed award"
                class="rounded-lg"
                loading="lazy"
                data-modal-image
                data-modal-full={superlatives.src}
              />
              <figcaption>Superlatives!</figcaption>
            </figure>
          </div>
        </div>
      </section>
      <section id="past-videos">
        <h3 class="text-center">Featured Videos</h3>
        <VideoGallery groups={videoGroups} />
      </section>
      <section id="photos">
        <h3 class="text-center">BTS Photos</h3>
        <AlbumGallery />
      </section>

      <section id="team">
        <h3 class="text-center">The Team</h3>
        <div class="team-grid">
          <div class="team-grid__item">
            <div class="team-profile">
              <Image
                src={doorway}
                alt="Doorway"
                class="team-profile__bg scale-x-[-1]"
              />
              <h4 class="team-profile__name">
                <a
                  href="https://www.andyzou.com/"
                  target="_blank"
                  rel="noreferrer noopener"
                  class="team-profile__link"
                >
                  Andy Zou
                </a>
              </h4>
              <Image src={andy} alt="Andy Zou" class="team-profile__portrait" />
            </div>
            <p class="team-profile__blurb">
              Andy Zou is a producer-director that has been working with
              comedians all over NYC for the better part of a decade. He's done
              videos for ClickHole, Snapchat, Funny or Die, and spent the last
              three years at Comedy Central Digital.
            </p>
          </div>

          <div class="team-grid__item">
            <div class="team-profile">
              <Image src={film} alt="Film" class="team-profile__bg translate-y-8" />
              <h4 class="team-profile__name">
                <a
                  href="https://www.katiesicking.com/"
                  target="_blank"
                  rel="noreferrer noopener"
                  class="team-profile__link"
                >
                  Katie Sicking
                </a>
              </h4>
              <Image
                src={katie}
                alt="Katie Sicking"
                class="team-profile__portrait"
              />
            </div>
            <p class="team-profile__blurb">
              Katie Sicking is a writer & director based in NYC. She's made
              multiple short films that have been selected for festivals such as
              WyIFF, Gold Coast, AFF and more. She's also created short films
              and digital series for Adult Swim and Comedy Central.
            </p>
          </div>

          <div class="team-grid__item">
            <div class="team-profile">
              <Image src={spaghetti} alt="Spaghetti" class="absolute bottom-0 translate-y-1/2 z-1" />
              <h4 class="team-profile__name">
                <a
                  href="https://www.aleccohen.cool/"
                  target="_blank"
                  rel="noreferrer noopener"
                  class="team-profile__link"
                >
                  Alec Cohen
                </a>
              </h4>
              <Image
                src={alec}
                alt="Alec Cohen"
                class="team-profile__portrait brightness-150"
              />
            </div>
            <p class="team-profile__blurb">
              Alec Cohen is a comedy director that has been featured by Comedy
              Central, Adult Swim, Above Average, Slamdance, Stareable, DUST,
              SeriesFest, NYTVF, MTV.com, Hatched.nyc, The New Yorker, Funny or
              Die, and more.
            </p>
          </div>
        </div>
      </section>
    </main>
    <Image src={tvvbestcrowd} alt="TVV Best Crowd" class="mt-4" />

    <Footer />

    <style>
      section {
        margin: 0 0 2em 0;
        padding: 1em;
        /* background-color: var(--color-neutral-foreground); */
        /* border: 4px solid var(--color-neutral-foreground);
    border-radius: 1em; */
        /* color: black; */
        /* box-shadow: 0 0 10px 0 rgba(0, 0, 0, 0.1); */
      }

      .team-grid {
        display: flex;
        flex-wrap: nowrap;
        justify-content: space-around;
        gap: 1.5rem;
      }

      .team-grid__item {
        position: relative;
        display: inline-block;
        flex: 1;
        min-width: 0;
      }

      .team-profile__bg {
        position: absolute;
        z-index: -1;
        height: 100%;
      }

      .team-profile {
        position: relative;
        z-index: 2;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
        text-align: center;
        border-radius: 1rem;
        box-shadow: var(--box-shadow);
        color: var(--color-neutral-foreground);
        flex: 1;
      }

      .team-profile__name {
        font-family: "Atelia";
        margin: 0;
      }

      .team-profile__portrait {
        margin: 0;
        aspect-ratio: 1 / 1;
        display: block;
        overflow: hidden;
        border-radius: 50%;
        width: 66%;
      }

      .team-profile__portrait img {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .team-profile__blurb {
        text-align: justify;
        margin: 3rem 0 0;
        font-size: 1rem;
        color: var(--gray);
      }

      figure {
        padding: 0.5em;
      }
      figcaption {
        text-align: center;
      }

      .how-it-works__list {
        list-style: none;
        padding: 0;
        flex-wrap: wrap;
      }

      .how-it-works__item {
        position: relative;
        flex: 1;
        min-width: 200px;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .how-it-works__frame {
        width: 100%;
        height: auto;
        display: block;
      }

      .how-it-works__content {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 80%;
        padding: 1rem;
        color: var(--color-neutral-foreground);
        text-align: center;
        font-size: 1rem;
        z-index: 1;
      }
    </style>
  </body>
</html>

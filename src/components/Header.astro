---
import { Image } from "astro:assets";
import logo from "../assets/img/TVV Logo.svg";
import hamburgerIcon from "../assets/img/WEB_HEADER/Hamburger.svg";
import closeIcon from "../assets/img/WEB_HEADER/CloseX.svg";
import mobileBg from "../assets/img/WEB_HEADER/Mobile BG 1.svg";
import desktopBg from "../assets/img/WEB_HEADER/Desktop BG 1.svg";
---

<header class="site-header my-8">
  <div class="site-header__inner">
    <div class="w-full relative overflow-hidden">
      <Image
        src={desktopBg}
        alt=""
        class="-z-10 w-full h-[408px] object-cover hidden md:block 2k:h-auto 2k:w-full"
      />
      <Image src={mobileBg} alt="" class="-z-10 w-full block md:hidden" />
      <Image
        src={logo}
        alt="Tootsies Video Vault Logo"
        class="absolute left-1/2 top-0 h-full -translate-x-1/2"
      />
    </div>
    <nav class="site-header__nav desktop-nav" aria-label="Primary navigation">
      <ul class="site-header__menu">
        <li>
          <a href="/#home" class="site-header__link">Home</a>
        </li>
        <li>
          <a href="/#how-it-works" class="site-header__link"> How It Works </a>
        </li>
        <li>
          <a href="/#past-videos" class="site-header__link"> Past Videos </a>
        </li>
        <li>
          <a href="/#photos" class="site-header__link"> BTS Photos </a>
        </li>
        <li>
          <a href="/#next-show" class="site-header__link"> Next Show </a>
        </li>
        <li>
          <a href="/#team" class="site-header__link"> About Us </a>
        </li>
        <li class="site-header__social">
          <a
            href="https://www.instagram.com/tootsiesvideovault/"
            target="_blank"
            rel="noopener noreferrer"
            class="site-header__link site-header__link--icon"
            aria-label="Follow Tootsies Video Vault on Instagram"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="40"
              height="40"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="w-40 h-40"
              ><rect width="20" height="20" x="2" y="2" rx="5" ry="5"
              ></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"
              ></path><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line></svg
            >
          </a>
        </li>
      </ul>
    </nav>
    <button
      class="menu-toggle"
      type="button"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      data-menu-toggle
    >
      <img
        src={hamburgerIcon.src}
        alt=""
        class="menu-toggle__icon"
        loading="lazy"
      />
    </button>
  </div>
</header>
<div class="mobile-overlay" data-mobile-overlay hidden></div>
<div class="mobile-menu" id="mobile-menu" data-mobile-menu hidden>
  <div class="mobile-menu__inner">
    <nav aria-label="Mobile navigation">
      <ul class="mobile-menu__list">
        <li>
          <button
            class="menu-close"
            type="button"
            aria-label="Close menu"
            data-menu-close
          >
            <img
              src={closeIcon.src}
              alt=""
              class="menu-close__icon"
              loading="lazy"
            />
          </button>
        </li>
        <li><a href="/#home" data-menu-link>Home</a></li>
        <li><a href="/#how-it-works" data-menu-link>How It Works</a></li>
        <li><a href="/#next-show" data-menu-link>Next Show</a></li>
        <li><a href="/#past-videos" data-menu-link>Past Videos</a></li>
        <li><a href="/#photos" data-menu-link>BTS Photos</a></li>
        <li><a href="/#team" data-menu-link>About Us</a></li>
        <li class="mobile-menu__social">
          <a
            href="https://www.instagram.com/tootsiesvideovault/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Follow Tootsies Video Vault on Instagram"
            data-menu-link
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="42"
              height="42"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="lucide lucide-instagram-icon lucide-instagram"
              ><rect width="20" height="20" x="2" y="2" rx="5" ry="5"
              ></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"
              ></path><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line></svg
            >
          </a>
        </li>
      </ul>
    </nav>
  </div>
  <img src={mobileBg.src} alt="" class="mobile-menu__divider" loading="lazy" />
</div>
<style>
  .site-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .site-header__inner {
    position: relative;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .site-header__brand {
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .site-header__logo {
    width: min(240px, 45vw);
    height: auto;
  }

  .site-header__menu {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 2rem;
  }

  .site-header__social {
    display: flex;
    justify-content: center;
  }

  .site-header__link {
    display: inline-flex;
    align-items: center;
    border-radius: 9999px;
    border: 1px solid transparent;
    color: var(--color-secondary);
    font-family: "Atelia";
    text-decoration: none;
    font-size: 1.75rem;
    transition:
      color 0.2s ease,
      border-color 0.2s ease,
      background-color 0.2s ease;
  }

  .site-header__link:hover,
  .site-header__link:focus-visible {
    text-decoration: underline;
  }

  .site-header__link.active {
    border-color: rgba(0, 0, 0, 0.2);
    background-color: rgba(0, 0, 0, 0.08);
    font-weight: 600;
  }

  .site-header__link--icon {
    padding-inline: 0.85rem;
  }

  .site-header__link--icon svg {
    width: 2.5rem;
    height: 2.5rem;
  }

  .menu-toggle {
    position: absolute;
    right: 1rem;
    top: 1rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem;
    border-radius: 9999px;
    cursor: pointer;
    z-index: 10;
  }

  .menu-toggle__icon {
    width: 32px;
    height: 32px;
  }

  .mobile-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
    opacity: 0;
    transition: opacity 0.25s ease;
    z-index: 90;
  }

  .mobile-overlay.is-active {
    opacity: 1;
  }

  .mobile-menu {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    flex-direction: column;
    transform: translateY(-100%);
    opacity: 0;
    transition:
      transform 0.3s ease,
      opacity 0.3s ease;
    backdrop-filter: blur(1px);
  }

  .mobile-menu.is-open {
    transform: translateY(0);
    opacity: 1;
  }

  .mobile-menu__inner {
    position: relative;
    padding: 1.5rem 1.25rem 0.5rem;
    color: white;
    height: fit-content;
    background: var(--color-neutral);
  }

  .mobile-menu__list {
    list-style: none;
    margin: 0;
    padding: 2rem 0 0;
    display: flex;
    flex-direction: column;
    text-align: right;
    font-size: 2rem;
    font-weight: 600;
    gap: 0.75rem;
  }

  .mobile-menu__list a {
    color: white;
    text-decoration: none;
  }

  .mobile-menu__list a:hover,
  .mobile-menu__list a:focus-visible {
    text-decoration: underline;
  }

  .mobile-menu__social {
    margin-left: auto;
  }

  .menu-close {
    position: absolute;
    right: 1rem;
    top: 1rem;
    border: none;
    background: transparent;
    padding: 0.5rem;
    cursor: pointer;
  }

  .menu-close__icon {
    width: 32px;
    height: 32px;
  }

  .mobile-menu__divider {
    width: 100%;
    height: auto;
    display: block;
    background: linear-gradient(
      to bottom,
      var(--color-neutral) 0%,
      var(--color-neutral) 50%,
      transparent 100%
    );
  }

  .site-header__nav {
    width: fit-content;
  }

  .desktop-nav {
    display: none;
  }

  @media (min-width: 768px) {
    .menu-toggle {
      display: none;
    }

    .desktop-nav {
      display: block;
    }

    .mobile-menu,
    .mobile-overlay {
      display: none;
    }

    .site-header__inner {
      justify-content: center;
      gap: 1.5rem;
    }
  }

  body.mobile-menu-open {
    overflow: hidden;
  }
</style>
<script is:inline type="module">
  const toggle = document.querySelector("[data-menu-toggle]");
  const closeBtn = document.querySelector("[data-menu-close]");
  const menu = document.querySelector("[data-mobile-menu]");
  const overlay = document.querySelector("[data-mobile-overlay]");
  const links = Array.from(document.querySelectorAll("[data-menu-link]"));
  const body = document.body;

  const openMenu = () => {
    menu?.removeAttribute("hidden");
    overlay?.removeAttribute("hidden");
    // Force a reflow to ensure the element is rendered in initial state
    void menu?.offsetHeight;
    // Then trigger the animation
    requestAnimationFrame(() => {
      menu?.classList.add("is-open");
      overlay?.classList.add("is-active");
      toggle?.setAttribute("aria-expanded", "true");
      body.classList.add("mobile-menu-open");
    });
  };

  const closeMenu = () => {
    menu?.classList.remove("is-open");
    overlay?.classList.remove("is-active");
    toggle?.setAttribute("aria-expanded", "false");
    body.classList.remove("mobile-menu-open");
    setTimeout(() => {
      menu?.setAttribute("hidden", "");
      overlay?.setAttribute("hidden", "");
    }, 300);
  };

  toggle?.addEventListener("click", () => {
    const isOpen = menu?.classList.contains("is-open");
    if (isOpen) {
      closeMenu();
    } else {
      openMenu();
    }
  });

  closeBtn?.addEventListener("click", closeMenu);
  overlay?.addEventListener("click", closeMenu);
  links.forEach((link) => link.addEventListener("click", closeMenu));
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") {
      closeMenu();
    }
  });
</script>

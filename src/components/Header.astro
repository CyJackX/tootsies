---
import { Image } from "astro:assets";
import logo from "../assets/img/logo.png";
---

<header class="site-header">
  <div class="site-header__inner">
    <a href="/#home" class="site-header__brand" aria-label="Back to top">
      <Image
        src={logo}
        alt="Tootsies Video Vault Logo"
        class="site-header__logo"
      />
    </a>
    <nav class="site-header__nav" aria-label="Primary navigation">
      <ul class="site-header__menu">
        <li>
          <a href="/#home" class="site-header__link">Home</a>
        </li>
        <li>
          <a href="/#how-it-works" class="site-header__link">
            How It Works
          </a>
        </li>
        <li>
          <a href="/#past-videos" class="site-header__link">
            Past Videos
          </a>
        </li>
        <li>
          <a href="/#photos" class="site-header__link">
            BTS Photos
          </a>
        </li>
        <li>
          <a href="/#next-show" class="site-header__link">
            Next Show
          </a>
        </li>
        <li>
          <a href="/#team" class="site-header__link">
            About Us
          </a>
        </li>
        <li class="site-header__social">
          <a
            href="https://www.instagram.com/tootsiesvideovault/"
            target="_blank"
            rel="noopener noreferrer"
            class="site-header__link site-header__link--icon"
            aria-label="Follow Tootsies Video Vault on Instagram"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="lucide lucide-instagram-icon lucide-instagram w-40 h-40"
              ><rect width="20" height="20" x="2" y="2" rx="5" ry="5"
              ></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"
              ></path><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line></svg
            >
          </a>
        </li>
      </ul>
    </nav>
  </div>
</header>
<style>
  .site-header {
    border-bottom: 1px solid rgba(0, 0, 0, 0.05);
    padding: 1rem;
  }

  .site-header__inner {
    max-width: 96rem;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .site-header__brand {
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .site-header__logo {
    width: min(240px, 45vw);
    height: auto;
  }

  .site-header__nav {
    width: fit-content;
  }

  .site-header__menu {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
  }

  .site-header__social {
    display: flex;
    justify-content: center;
  }

  .site-header__link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0 0.5rem;
    border-radius: 9999px;
    border: 1px solid transparent;
    color: var(--color-secondary);
    font-family: "Atelia";
    text-decoration: none;
    transition:
      color 0.2s ease,
      border-color 0.2s ease,
      background-color 0.2s ease;
  }

  .site-header__link:hover,
  .site-header__link:focus-visible {
    text-decoration: underline;
  }

  .site-header__link.active {
    border-color: rgba(0, 0, 0, 0.2);
    background-color: rgba(0, 0, 0, 0.08);
    font-weight: 600;
  }

  .site-header__link--icon {
    padding-inline: 0.85rem;
  }

  .site-header__link--icon svg {
    width: 1.5rem;
    height: 1.5rem;
  }

  @media (min-width: 768px) {

    .site-header__nav {
      width: fit-content;
    }
  }
</style>

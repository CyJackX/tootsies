---
import { Swiper, SwiperWrapper, SwiperSlide } from "astro-swiper";
import SwiperNavButton from "./SwiperNavButton.astro";
import {
  getVideoEmbed,
  type VideoGroup,
} from "../utils/videoEmbeds";

interface Props {
  groups?: VideoGroup[];
}

const { groups = [] } = Astro.props as Props;

const preparedGroups = groups.map((group) => ({
  ...group,
  videos: group.videos.map((video) => ({
    video,
    embed: getVideoEmbed(video),
  })),
}));

const slugify = (value: string) =>
  value
    .toLowerCase()
    .trim()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/(^-|-$)/g, "");

---

{preparedGroups.length === 0 ? (
  <p class="text-center text-sm opacity-70">
    Highlight reels coming soon.
  </p>
) : (
  <div class="video-gallery">
    <div class="video-toggle flex flex-wrap gap-2 justify-center mb-4">

      <!-- Toggle buttons for each group -->
      {preparedGroups.map((group, index) => (
        <button
          type="button"
          class={`video-toggle__btn tab-toggle__btn ${index === 0 ? "is-active" : ""}`}
          data-video-toggle
          data-target={slugify(group.label)}
          aria-pressed={index === 0 ? "true" : "false"}
        >
          <span class="video-toggle__label">{group.label}</span>
          {group.date && (
            <span class="video-toggle__date">
              {new Date(group.date).toLocaleDateString(undefined, {
                year: "numeric",
                month: "short",
                day: "numeric",
              })}
            </span>
          )}
        </button>
      ))}
    </div>
    <div class="video-carousels space-y-6">
      {preparedGroups.map((group, index) => {
        const groupKey = slugify(group.label);
        const navNext = `swiper-button-next-${index}`;
        const navPrev = `swiper-button-prev-${index}`;

        return (
          <div
            class="video-carousels__panel flex items-center justify-center"
            data-video-panel
            data-group={groupKey}
            hidden={index === 0 ? undefined : true}
          >
            <SwiperNavButton
              direction="prev"
              class={`${navPrev}`}
              ariaLabel="Previous slide"
            />
            <Swiper
              options={{
                slidesPerView: 1,
                spaceBetween: 8,
                navigation: {
                  nextEl: `.${navNext}`,
                  prevEl: `.${navPrev}`,
                },
                breakpoints: {
                  768: {
                    slidesPerView: 2,
                  },
                },
                grid: {
                  fill: "row",
                  rows: 2,
                },
              }}
              class="not-content"
            >
              <SwiperWrapper>
                {group.videos.map((item) => (
                  <SwiperSlide>
                    {(() => {
                      const { video, embed } = item;

                      // If the video is not embeddable, show a fallback with a link to the video
                      if (!embed) {
                        return (
                          <div class="video-fallback" data-video-fallback>
                            <p>Unable to embed this video. Click to open:</p>
                            <a
                              href={video.url}
                              target="_blank"
                              rel="noopener noreferrer"
                            >
                              {video.url}
                            </a>
                          </div>
                        );
                      }

                      // If the video is embeddable, show the iframe
                      if (embed.iframe) {
                        return (
                          <div class="video-frame">
                            <iframe
                              data-src={embed.iframe.src}
                              data-video-embed
                              title={embed.iframe.title}
                              loading="lazy"
                              allowfullscreen={true}
                              referrerpolicy="strict-origin-when-cross-origin"
                            ></iframe>
                            <div class="max-w-2/3 mx-auto pt-4 text-center">
                              <h3 >{video.title}</h3>
                              <p >By {video.description.credits}</p>
                              {video.description.details && (
                                <p class="text-sm">{video.description.details}</p>
                              )}
                            </div>
                          </div>
                        );
                      }

                      return null;
                    })()}
                  </SwiperSlide>
                ))}
              </SwiperWrapper>
            </Swiper>
            <SwiperNavButton
              direction="next"
              class={`${navNext}`}
              ariaLabel="Next slide"
            />
          </div>
        );
      })}
    </div>
    <script type="module" is:inline>
      const toggles = Array.from(
        document.querySelectorAll("[data-video-toggle]")
      );
      const panels = Array.from(
        document.querySelectorAll("[data-video-panel]")
      );
      const embeds = Array.from(
        document.querySelectorAll("[data-video-embed]")
      );

      const loadIframe = (iframe) => {
        if (!iframe || iframe.dataset.loaded === "true") return;
        const src = iframe.dataset.src;
        if (!src) return;
        iframe.src = src;
        iframe.dataset.loaded = "true";
      };

      // Lazy-load embeds when they approach viewport
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              loadIframe(entry.target);
              observer.unobserve(entry.target);
            }
          });
        },
        { rootMargin: "200px" }
      );

      embeds.forEach((iframe) => observer.observe(iframe));

      if (toggles.length && panels.length) {
        const activate = (next) => {
          const target = next.dataset.target;
          if (!target) return;

          toggles.forEach((toggle) => {
            const isActive = toggle === next;
            toggle.classList.toggle("is-active", isActive);
            toggle.setAttribute("aria-pressed", isActive ? "true" : "false");
          });

          panels.forEach((panel) => {
            const matches = panel.dataset.group === target;
            panel.toggleAttribute("hidden", !matches);
            if (matches) {
              const swiperRoot = panel.querySelector(".swiper");
              if (swiperRoot?.swiper?.update) {
                swiperRoot.swiper.update();
              }
            }
          });
        };

        toggles.forEach((toggle) => {
          toggle.addEventListener("click", () => activate(toggle));
        });

        const initiallyActive =
          toggles.find((btn) => btn.classList.contains("is-active")) ??
          toggles[0];
        if (initiallyActive) activate(initiallyActive);
      }
    </script>
  </div>
)}

<style>
  .video-frame {
    margin: 0 auto;
  }

  .video-frame iframe {
    width: 100%;
    aspect-ratio: 16 / 9;
    border: none;
    border-radius: 0.75rem;
  }

  .video-fallback {
    width: min(90vw, 960px);
    padding: 1rem;
    border-radius: 0.75rem;
    border: 1px solid rgba(0, 0, 0, 0.1);
    background: rgba(255, 255, 255, 0.7);
  }

  .video-carousels__panel {
    gap: 0.75rem;
  }

  .video-carousels__panel > .swiper {
    flex: 1 1 0;
    min-width: 0;
  }
</style>


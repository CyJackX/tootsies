---
import SwiperCarousel from "./SwiperCarousel.astro";
import { SwiperSlide } from "astro-swiper";
import {
  getVideoEmbed,
  type VideoItem,
  type VideoEmbed,
  type VideoGroup,
} from "../utils/videoEmbeds";

interface Props {
  groups?: VideoGroup[];
}

const { groups = [] } = Astro.props as Props;

type PreparedVideo = {
  video: VideoItem;
  embed: VideoEmbed | null;
};

const preparedGroups = groups.map((group) => ({
  ...group,
  videos: group.videos.map((video) => ({
    video,
    embed: getVideoEmbed(video),
  })),
}));

---

{preparedGroups.length === 0 ? (
  <p class="text-center text-sm opacity-70">
    Highlight reels coming soon.
  </p>
) : (
  <div class="video-gallery">
    <div class="video-toggle flex flex-wrap gap-2 justify-center mb-4">
      {preparedGroups.map((group, index) => (
        <button
          type="button"
          class={`video-toggle__btn ${index === 0 ? "is-active" : ""}`}
          data-video-toggle
          data-target={group.id}
          aria-pressed={index === 0 ? "true" : "false"}
        >
          <span class="video-toggle__label">{group.label}</span>
          {group.date && (
            <span class="video-toggle__date">
              {new Date(group.date).toLocaleDateString(undefined, {
                year: "numeric",
                month: "short",
                day: "numeric",
              })}
            </span>
          )}
        </button>
      ))}
    </div>
    <div class="video-carousels space-y-6">
      {preparedGroups.map((group, index) => (
        <div
          class="video-carousels__panel"
          data-video-panel
          data-group={group.id}
          hidden={index === 0 ? undefined : true}
        >
          <SwiperCarousel
            options={{
              loop: true,
              spaceBetween: 16,
              lazyPreloadPrevNext: 1,
              slidesPerView: 2,
              centeredSlides: true,
            }}
          >
            {group.videos.map((item) => (
              <SwiperSlide class="w-auto!">
                {(() => {
                  const { video, embed } = item;
                  if (!embed) {
                    return (
                      <div class="video-fallback" data-video-fallback>
                        <p>Unable to embed this video. Please open directly:</p>
                        <a
                          href={video.url}
                          target="_blank"
                          rel="noopener noreferrer"
                        >
                          {video.url}
                        </a>
                      </div>
                    );
                  }

                  if (embed.html) {
                    return (
                      <div class="video-html" set:html={embed.html}></div>
                    );
                  }

                  if (embed.iframe) {
                    const allowFullscreen = embed.iframe.allowFullscreen
                      ? true
                      : undefined;
                    return (
                      <div class="video-frame">
                        <iframe
                          src={embed.iframe.src}
                          title={embed.iframe.title}
                          allow={embed.iframe.allow}
                          loading="lazy"
                          allowfullscreen={allowFullscreen}
                          referrerpolicy="strict-origin-when-cross-origin"
                        ></iframe>
                        {video.description && (
                          <p class="video-caption">{video.description}</p>
                        )}
                      </div>
                    );
                  }

                  return null;
                })()}
              </SwiperSlide>
            ))}
          </SwiperCarousel>
        </div>
      ))}
    </div>
    <script type="module" is:inline>
      import { initToggleGallery } from "../utils/initToggleGallery";
      initToggleGallery({
        toggleSelector: "[data-video-toggle]",
        panelSelector: "[data-video-panel]",
        getTarget: (toggle) => toggle.dataset.target,
        matchPanel: (panel, target) => panel.dataset.group === target,
      });
    </script>
  </div>
)}

<style>
  .video-toggle__btn {
    padding: 0.5rem 2rem;
    border-radius: 9999px;
    border: 1px solid rgba(0, 0, 0, 0.15);
    background-color: rgb(var(--color-neutral-surface));
    transition: background-color 0.2s ease, color 0.2s ease,
      border-color 0.2s ease;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.125rem;
  }

  .video-toggle__btn:hover {
    background-color: rgba(0, 0, 0, 0.08);
  }

  .video-toggle__btn.is-active {
    background-color: rgb(var(--color-secondary));
    border-color: transparent;
    color: white;
  }

  .video-frame {
    width: min(90vw, 960px);
  }

  .video-frame iframe {
    width: 100%;
    aspect-ratio: 16 / 9;
    border: none;
    border-radius: 0.75rem;
    box-shadow: 0 16px 32px rgba(0, 0, 0, 0.35);
  }

  .video-caption {
    margin-top: 0.5rem;
    text-align: center;
    font-size: 0.875rem;
    opacity: 0.8;
  }

  .video-fallback {
    width: min(90vw, 960px);
    padding: 1rem;
    border-radius: 0.75rem;
    border: 1px solid rgba(0, 0, 0, 0.1);
    background: rgba(255, 255, 255, 0.7);
  }
</style>


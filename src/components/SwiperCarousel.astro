---
import {
  Swiper,
  SwiperWrapper,
  SwiperSlide,
  SwiperButtonPrev,
  SwiperButtonNext,
} from "astro-swiper";
import type { AstroSwiperType } from "astro-swiper";

type Props = {
  options?: AstroSwiperType["options"]; 
};

const astroSwiperOptions: AstroSwiperType = {
  options: {
    ...Astro.props.options,
    navigation: {
      nextEl: ".swiper-button-next",
      prevEl: ".swiper-button-prev",
    },
  },
};
---

<!-- Slider main container -->
<Swiper options={astroSwiperOptions.options} class="not-content">
  <!-- Additional required wrapper -->
  <SwiperWrapper>
    <slot />

    <!-- navigation buttons -->
  </SwiperWrapper>
  <SwiperButtonPrev />
  <SwiperButtonNext />
</Swiper>
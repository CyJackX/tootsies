---
import { Image } from "astro:assets";
import arrowSvg from "../assets/img/WEB_VIDEOS PHOTOS/Arrow.svg";

interface Props {
  direction: "prev" | "next";
  class?: string;
  ariaLabel?: string;
}

const { direction, class: className = "", ariaLabel } = Astro.props as Props;
const isPrev = direction === "prev";
const label = ariaLabel ?? (isPrev ? "Previous slide" : "Next slide");
---

<button
  type="button"
  class={`nav-button ${className}`.trim()}
  aria-label={label}
>
  <Image
    src={arrowSvg}
    alt=""
    aria-hidden="true"
    width={66}
    height={241}
    class={`nav-button__icon ${isPrev ? "is-prev" : "is-next"}`}
  />
</button>

<style>
  .nav-button__icon {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .nav-button__icon.is-prev {
    transform: rotate(180deg);
  }
</style>


---
type ImageSource =
  | string
  | {
      src: string;
      alt?: string;
    };

export type Props = {
  image: ImageSource;
  blurb: string;
  name?: string;
  link?: string;
  class?: string;
};

const { image, blurb, name, link, class: className } = Astro.props as Props;

const resolvedImage =
  typeof image === "string"
    ? { src: image, alt: name ?? "" }
    : { src: image.src, alt: image.alt ?? name ?? "" };
---

<article class:list={["profile-card", className]}>
  {
    name && (
      <h4 class="profile-card__name">
        {link ? (
          <a
            href={link}
            target="_blank"
            rel="noreferrer noopener"
            class="profile-card__link"
          >
            {name}
          </a>
        ) : (
          name
        )}
      </h4>
    )
  }
  <figure class="profile-card__media">
    <img
      src={resolvedImage.src}
      alt={resolvedImage.alt}
      loading="lazy"
      decoding="async"
    />
  </figure>
  <div class="profile-card__body">
    
    <p class="profile-card__blurb">{blurb}</p>
  </div>
</article>

<style>
  .profile-card {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    align-items: center;
    gap: 1.5rem;
    text-align: center;
    background: var(--color-neutral);
    border-radius: 1rem;
    box-shadow: var(--box-shadow);
    padding: 2rem;
    color: var(--color-neutral-foreground);
    flex: 1;
    min-width: 16rem;
    max-width: 20rem;
  }

  .profile-card__media {
    margin: 0;
    aspect-ratio: 1 / 1;
    display: grid;
    place-items: center;
    overflow: hidden;
    border-radius: 50%;
    width: 66%;
  }

  .profile-card__media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .profile-card__body {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .profile-card__name {
    font-family: "Atelia";
  }

  .profile-card__link {
    color: var(--color-secondary);

  }

  .profile-card__link:hover,
  .profile-card__link:focus-visible {
    text-decoration: underline;
  }

  .profile-card__blurb {
    text-align: justify;
    margin: 0;
    font-size: 1rem;
    color: var(--gray);
  }
</style>
